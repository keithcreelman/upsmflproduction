# ETL runtime overrides
MFL_DB_PATH=/absolute/path/to/mfl_database.db
MFL_ETL_ARTIFACT_DIR=/absolute/path/to/output_artifacts
MFLTEST_COMMISHCOOKIE=<test_league_commissioner_cookie>
MFL_TAG_TRACKING_JSON=/absolute/path/to/tag_tracking.json
MFL_TAG_EXCLUSIONS_JSON=/absolute/path/to/tagging_2026_exclusions.json
MFL_SALARY_ADJUSTMENTS_URL=https://wwwXX.myfantasyleague.com/2025/export?TYPE=salaryAdjustments&L=<LEAGUE_ID>&APIKEY=<API_KEY>&JSON=0
MFL_SALARY_ADJUSTMENTS_REQUIRE_LIVE_DROP_FEED=1
MFL_SALARY_ADJUSTMENTS_ALLOW_SNAPSHOT_FALLBACK=1
