# ETL runtime overrides
MFL_DB_PATH=/absolute/path/to/mfl_database.db
MFL_ETL_ARTIFACT_DIR=/absolute/path/to/output_artifacts
MFL_TAG_TRACKING_JSON=/absolute/path/to/tag_tracking.json
MFL_TAG_EXCLUSIONS_JSON=/absolute/path/to/tagging_2026_exclusions.json
MFL_SALARY_ADJUSTMENTS_URL=https://wwwXX.myfantasyleague.com/2026/export?TYPE=salaryAdjustments&L=<LEAGUE_ID>&APIKEY=<API_KEY>&JSON=0
MFL_SALARY_ADJUSTMENTS_FILE=/absolute/path/to/salaryAdjustments.xml
MFL_SALARY_ADJUSTMENTS_SPECIAL_CASES_FILE=/absolute/path/to/salary_adjustments_special_cases.json
MFL_SALARY_ADJUSTMENTS_TIMEOUT=30
